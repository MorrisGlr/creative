---
// Renders one media item (image|video|model) with:
// - fade/scale-in on scroll
// - optional dominant-color background change when it enters view
import type { MediaItem, PhotoMetadata } from "../scripts/content";
const { item, index, bgColorize = false, showPhotoMetadata = false } = Astro.props as {
  item: MediaItem; index: number; bgColorize?: boolean; showPhotoMetadata?: boolean;
};
const imageMeta = item.type === 'image' ? ((item as any).meta as PhotoMetadata | undefined) : undefined;
const photoMeta = imageMeta ?? {};
const lensLine =
  photoMeta.lensMake && photoMeta.lensModel
    ? `${photoMeta.lensMake} ${photoMeta.lensModel}`.trim()
    : photoMeta.lensModel ?? photoMeta.lensMake;
const hasHeader = Boolean(photoMeta.cameraMake || photoMeta.cameraModel || photoMeta.cameraType || lensLine);
const hasDetails = Boolean(
  photoMeta.focalLength ||
    photoMeta.exposureTime ||
    photoMeta.aperture ||
    photoMeta.iso
);
const attributionText =
  typeof (item as any).attribution === 'string' ? (item as any).attribution.trim() : '';
const hasAttribution = Boolean(attributionText);
const captionFill =
  item.type === 'image'
    ? (item as any).src
    : item.type === 'video'
      ? (item as any).poster ?? (item as any).src ?? ((item as any).sources?.[0]?.src)
      : (item as any).src;
---

<div
  class="media-block media-shell"
  data-index={index}
  data-bg={bgColorize ? '1' : '0'}
  data-caption="0"
  data-attribution={hasAttribution ? '1' : '0'}
  data-attribution-text={hasAttribution ? attributionText : undefined}
>
  {item.type === 'image' && (
    <figure class="media-frame">
      <div class="media-visual">
        <div class="media-visual__media">
          <img
            src={(item as any).src}
            alt={(item as any).alt ?? ''}
            loading="lazy"
            decoding="async"
            class="object-cover warp-target"
            data-warp-target
          />
        </div>
        {showPhotoMetadata ? (
          <div class="photo-meta-panel">
            <div class="photo-meta-panel__inner">
              {photoMeta.cameraMake && (
                <p class="photo-meta-line photo-meta-line--highlight">
                  {photoMeta.cameraMake.toUpperCase()}
                </p>
              )}
              {photoMeta.cameraModel && (
                <p class="photo-meta-line photo-meta-line--highlight">
                  {photoMeta.cameraModel.toUpperCase()}
                </p>
              )}
              {photoMeta.cameraType && (
                <p class="photo-meta-line photo-meta-line--highlight">
                  CAMERA: {photoMeta.cameraType.toUpperCase()}
                </p>
              )}
              {lensLine && (
                <p class="photo-meta-line">LENS: {lensLine}</p>
              )}
              {hasHeader && hasDetails ? (
                <div class="photo-meta-spacer" aria-hidden="true"></div>
              ) : null}
              {photoMeta.focalLength && (
                <p class="photo-meta-line">FOCAL LENGTH: {photoMeta.focalLength}</p>
              )}
              {photoMeta.exposureTime && (
                <p class="photo-meta-line">EXPOSURE TIME: {photoMeta.exposureTime}</p>
              )}
              {photoMeta.aperture && (
                <p class="photo-meta-line">APERTURE: {photoMeta.aperture}</p>
              )}
              {photoMeta.iso && (
                <p class="photo-meta-line">ISO: {photoMeta.iso}</p>
              )}
            </div>
          </div>
        ) : null}
      </div>
      {hasAttribution ? (
        <figcaption class="media-attribution">{attributionText}</figcaption>
      ) : null}
    </figure>
  )}

  {item.type === 'video' && (
    <figure class="media-frame">
      <div class="media-visual">
        <div class="media-visual__media media-visual__media--video">
          <video
            playsinline
            muted
            autoplay
            loop
            preload="metadata"
            poster={(item as any).poster ?? ''}
            class="object-cover warp-target"
            data-warp-target
          >
            {(item as any).sources.map((s: any) => <source src={s.src} type={s.type ?? ''} />)}
          </video>
        </div>
      </div>
      {hasAttribution ? (
        <figcaption class="media-attribution">{attributionText}</figcaption>
      ) : null}
    </figure>
  )}

  {item.type === 'model' && (
    <figure class="media-frame">
      <div class="media-visual">
        <div class="media-visual__media">
          <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
          <model-viewer
            src={(item as any).src}
            ios-src={(item as any).usdz ?? undefined}
            camera-controls
            auto-rotate
            ar
            class="bg-black/5"
            alt={(item as any).alt ?? '3D model'}
          />
        </div>
      </div>
      {hasAttribution ? (
        <figcaption class="media-attribution">{attributionText}</figcaption>
      ) : null}
    </figure>
  )}
</div>

  {(item as any).caption ? (
    <div
      class="media-caption-block"
      data-caption-for={index}
      style={captionFill ? `--caption-fill: url("${captionFill}")` : undefined}
    >
      <p
        class={`media-caption${captionFill ? ' media-caption--fill' : ''}`}
        data-split-caption
        style={captionFill ? `--caption-fill: url("${captionFill}"); background-image: url("${captionFill}")` : undefined}
      >
        {(item as any).caption}
      </p>
    </div>
  ) : null}
