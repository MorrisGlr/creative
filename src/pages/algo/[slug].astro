---
// src/pages/algo/[slug].astro
import Layout from "../../layouts/Layout.astro";
import AlbumMedia from "../../components/AlbumMedia.astro";
import { getAlbums, getAlbum, resolveAlbumMediaUrls } from '../../scripts/content';
import { withBase } from '../../scripts/paths';

export async function getStaticPaths() {
  return getAlbums('algo').map((album) => ({
    params: { slug: album.slug },
    props: { albumSlug: album.slug },
  }));
}

const { slug } = Astro.params;
if (!slug) throw new Error("Missing slug");

const albumRaw = getAlbum('algo', slug);
if (!albumRaw) {
  // Astro will render your 404 (or you can throw)
  throw new Error(`Album not found: ${slug}`);
}

// Resolve media filenames to emitted URLs:
const album = await resolveAlbumMediaUrls('algo', slug, albumRaw);
const titleImages: string[] = [];
const initialFill = undefined;
const titleFillStyle = undefined;

const trimmed = (value?: string) => value?.trim() || undefined;
const displayDate = trimmed(album.displayDate) || trimmed(album.dateCreated) || trimmed(album.date);
const displayDateSource =
  trimmed(album.displayDate) ? 'displayDate' :
  trimmed(album.dateCreated) ? 'dateCreated' :
  trimmed(album.date) ? 'date' :
  undefined;
---

<Layout title={album.title}>
  <section class="project-hero">
    <p class="project-hero__eyebrow">Project</p>
    <h1
      class="project-hero__title project-hero__title--plain"
      data-split-title
      data-title-images=""
      data-title-fill-url=""
      style={titleFillStyle}
    >
      {album.title}
    </h1>
    {displayDate ? (
      <p class="project-hero__date" data-display-date-source={displayDateSource ?? ''}>
        {displayDate}
      </p>
    ) : null}
    {album.description ? (
      <p class="project-hero__description">{album.description}</p>
    ) : null}
  </section>
  <script type="module">
    const titleEl = document.querySelector('.project-hero__title');
    if (titleEl) {
      const imgsRaw = titleEl.dataset.titleImages;
      if (imgsRaw) {
        try {
          const imgs = JSON.parse(imgsRaw);
          if (Array.isArray(imgs) && imgs.length) {
            const pick = imgs[Math.floor(Math.random() * imgs.length)];
            if (pick) {
              titleEl.style.setProperty('--title-fill', `url("${pick}")`);
              titleEl.style.backgroundImage = `url("${pick}")`;
            }
          }
        } catch {}
      }
      const cs = getComputedStyle(titleEl);
      console.info('[title-fill]', {
        page: location.pathname,
        data: titleEl.dataset,
        inline: titleEl.getAttribute('style'),
        cssVar: cs.getPropertyValue('--title-fill'),
        bgImage: cs.backgroundImage,
      });
    } else {
      console.warn('[title-fill] title element not found on page', location.pathname);
    }

    const dateEl = document.querySelector('.project-hero__date');
    if (dateEl) {
      console.info('[project-date]', {
        page: location.pathname,
        text: dateEl.textContent?.trim(),
        data: dateEl.dataset,
      });
    } else {
      console.warn('[project-date] date element missing on page', location.pathname);
    }
  </script>

  {/* Media stream per your scroll spec */}
  <section class="media-stream space-y-16 mt-10">
    {album.media.map((m, i) => (
      <AlbumMedia item={m} index={i} bgColorize={album.options?.bgFromDominantColor ?? false} />
    ))}
  </section>

  {/* Bottom: links back to section (and later, related albums) */}
  <footer class="mt-24 border-t pt-6">
    <a href={withBase("/algo/")} class="underline">More algorithm art projects</a>
  </footer>
</Layout>
