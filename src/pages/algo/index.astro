---
// src/pages/algo/index.astro
import Layout from "../../layouts/Layout.astro";
import { getAlbums, resolveAlbumMediaUrls } from '../../scripts/content';
const albumsRaw = getAlbums('algo');
const albums = await Promise.all(
  albumsRaw.map((album) => resolveAlbumMediaUrls('algo', album.slug, album))
);

---

<Layout title="Algorithm Art">
  <h1 class="text-2xl font-semibold mb-6">Algorithm Art</h1>

  <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 justify-items-center">
    {albums.map(a => (
      <li class="group w-full max-w-[22rem]">
        <a href={`/algo/${a.slug}/`} class="block text-center">
          {a.cover ? (
            a.cover.match(/\.(mp4|webm|mov)$/i) ? (
              <video
                src={a.cover}
                playsinline
                muted
                loop
                autoplay
                preload="metadata"
                class="aspect-[3/2] w-full rounded-xl object-cover transition-transform group-hover:scale-[1.02]"
              />
            ) : (
              <img
                src={a.cover}
                alt={a.title}
                loading="lazy"
                decoding="async"
                class="aspect-[3/2] w-full rounded-xl object-cover transition-transform group-hover:scale-[1.02]"
              />
            )
          ) : null}
          <div class="mt-3">
            <h2 class="text-lg font-medium">{a.title}</h2>
            {a.description ? <p class="text-sm opacity-70 line-clamp-2">{a.description}</p> : null}
          </div>
        </a>
      </li>
    ))}
  </ul>
</Layout>
