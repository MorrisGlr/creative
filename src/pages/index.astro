---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";

const tiles = [
  { href: "/photos/",   title: "Photos",   desc: "Film & digital albums" },
  { href: "/textbooks/",title: "Textbook Sculptures", desc: "Carved textbook sculptures" },
  { href: "/algo/",     title: "Algorithm Art",     desc: "Animated algorithmic art" },
  { href: "/paper/",    title: "Paper Layering",    desc: "Paper craft & layering" },
];
---

<Layout title="Creative Work">
  <header class="home-hero">
    <h1>Creative Work</h1>
    <p>Explore four worlds.</p>
  </header>

  <main class="home-grid" aria-label="Sections">
    {tiles.map(t => (
      <a class="home-card" href={t.href}>
        <h2>{t.title}</h2>
        <p>{t.desc}</p>
      </a>
    ))}
  </main>
</Layout>

<style>
  .home-hero { text-align:center; margin: 4rem auto 2rem; padding: 0 1rem; }
  .home-hero h1 { font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 .5rem; }
  .home-hero p { opacity: .8; margin: 0 auto; max-width: 60ch; }

  .home-grid {
    --gap: 1.25rem;
    display: grid;
    gap: var(--gap);
    grid-template-columns: repeat(auto-fit, minmax(min(15rem, 100%), 1fr));
    padding: 1rem;
    max-width: 1100px;
    margin: 0 auto 4rem;
  }
  .home-card {
    display: block;
    border-radius: 9999px; /* pill */
    padding: 1.25rem 1.5rem;
    background: color-mix(in oklab, Canvas 80%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in oklab, CanvasText 12%, transparent);
    text-decoration: none;
    transition: transform .18s ease, background-color .18s ease, border-color .18s ease;
  }
  .home-card:hover { transform: translateY(-2px); }
  .home-card h2 { margin: 0 0 .25rem; font-size: 1.2rem; }
  .home-card p { margin: 0; opacity: .75; }
</style>